---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="CaribeConf Barranquilla, Colombia (Coming soon 2026)" />
    {
      ENV !== 'production' &&
        <meta name="robots" content="NOINDEX, NOFOLLOW">
    }
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>
      {
        title
          ? title + ' | Caribe Conf 2026'
          : 'Caribe Conf - Conferencia de Comunidades Tech en Barranquilla, Colombia (Coming soon 2026)'
      }
    </title>
    <meta
      name="description"
      content="Únete a CaribeConf Barranquilla, Colombia (Coming soon 2026). La conferencia de comunidades tech más esperada del Caribe. Charlas inspiradoras, networking y oportunidades únicas para desarrolladores, diseñadores y entusiastas de la tecnología. ¡No te lo pierdas!"
    />
    <meta
      name="keywords"
      content="Caribe Dev, CaribeDev, Caribe Conf, CaribeConf. JavaScript, Colombia, Barranquilla, Conferencias, Programación, Comunidades Tech"
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://caribeconf.com" />

    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:title" content="CaribeConf Barranquilla, Colombia (Coming soon 2026)" />
    <meta
      property="og:description"
      content="Conferencia de Comunidades Tech en Barranquilla, Colombia (Coming soon 2026)"
    />
    <meta property="og:url" content="https://caribeconf.com" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@caribedev" />
    <meta name="twitter:creator" content="@caribedev" />
    <meta name="twitter:title" content="CaribeConf Barranquilla, Colombia (Coming soon 2026)" />
    <meta
      name="twitter:description"
      content="Conferencia de Comunidades Tech en Barranquilla, Colombia (Coming soon 2026)"
    />
    <meta name="twitter:image" content={image} />

    {/* <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /> */}
    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
