---
import { ClientRouter } from 'astro:transitions';
import { DOMAIN, ENV } from "astro:env/client"

import '@shared/styles/settings/typography.css'
import '@shared/styles/global.css'
import '@shared/styles/helpers/fonts.css'


interface Props {
  title?: string
}

const title = Astro.props.title
const image = DOMAIN + '/images/og.png'

