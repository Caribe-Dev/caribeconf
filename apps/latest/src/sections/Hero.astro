---
import { Image, getImage } from 'astro:assets';

import Layout from '@shared/components/Layout.astro';

import { BUY_TICKET_URL } from "@/utils/constants";

import InterledgerPng from '@/public/images/interledger.png';
import CloudsSvg from '@/public/images/clouds.svg';
import AguaPng from '@/public/images/agua.png';
import BalsaOnePng from '@/public/images/balsa-1.png';
import BalsaTwoPng from '@/public/images/balsa-2.png';
import PlayaPng from '@/public/images/playa.png';
import SolPng from '@/public/images/sol.png';
import PalmaPng from '@/public/images/palmeras-derecha.png';
import PalmasPng from '@/public/images/palmeras-izquierda.png';
import MuellePuenteSvg from '@/public/images/muelle-puente.svg';
import BirdsSvg from '@/public/images/birds.svg';

const [
  preloadAgua, preloadPlaya, preloadSol,
  preloadPalmas, preloadPalma,
  preloadBalsaOne, preloadBalsaTwo,
  preloadClouds, preloadMuelle, preloadBirds,
] = await Promise.all([
  getImage({ src: AguaPng, format: 'webp' }),
  getImage({ src: PlayaPng, format: 'webp' }),
  getImage({ src: SolPng, format: 'webp', width: 450 }),
  getImage({ src: PalmasPng, format: 'webp', width: 450 }),
  getImage({ src: PalmaPng, format: 'webp', width: 450 }),
  getImage({ src: BalsaOnePng, format: 'webp' }),
  getImage({ src: BalsaTwoPng, format: 'webp' }),
  getImage({ src: CloudsSvg }),
  getImage({ src: MuellePuenteSvg }),
  getImage({ src: BirdsSvg }),
])
---

<link rel="preload" as="image" href={preloadAgua.src} fetchpriority="high" />
<link rel="preload" as="image" href={preloadPlaya.src} fetchpriority="high" />
<link rel="preload" as="image" href={preloadSol.src} fetchpriority="high" />
<link rel="preload" as="image" href={preloadClouds.src} fetchpriority="high" />
<link rel="preload" as="image" href={preloadMuelle.src} />
<link rel="preload" as="image" href={preloadBirds.src} />
<link rel="preload" as="image" href={preloadBalsaOne.src} />
<link rel="preload" as="image" href={preloadBalsaTwo.src} />
<link rel="preload" as="image" href={preloadPalmas.src} media="(min-width: 1024px)" />
<link rel="preload" as="image" href={preloadPalma.src} media="(min-width: 1024px)" />

<section class='overflow-hidden w-full'>
  <div class='overflow-hidden relative bg-gradient-hero h-[900px] md:h-[1000px]'>
    <div class='absolute top-[50px] md:top-[80px] left-0 right-0 bottom-0 pointer-events-none'>
      <Image class='w-full h-full object-cover' src={CloudsSvg} alt='Clouds image' />
    </div>
    <Layout class='relative flex justify-center top-25 sm:top-30 lg:top-42 z-90'>
      <div class='flex justify-center flex-col gap-4 max-w-[805px]'>
        <div class="flex justify-center">
          <a
            href="https://interledger.org"
            target="_blank"
            rel="noopener noreferrer"
            class="hero-sponsor-badge inline-flex items-center gap-2 rounded-full pl-3 pr-4 py-1.5 md:pl-4 md:pr-5 md:py-2 transition-all"
          >
            <span class="uppercase text-white/85 text-xs md:text-sm font-bold tracking-widest">By</span>
            <Image
              class="h-8 md:h-10 w-auto"
              src={InterledgerPng}
              alt="Interledger Foundation"
              width={604}
              height={166}
              loading="eager"
            />
          </a>
        </div>
        <div class="flex flex-col justify-center">
          <span class='uppercase text-purple font-bold tracking-[2px] text-sm text-center'>
            conferencia de comunidades tech
          </span>
          <h1 class="text-center">CaribeConf 2026</h1>
          <p class="h5 font-medium text-center">
            Tecnología que se amplifica <br /> desde el Caribe
          </p>
        </div>
        <p class='small-text font-medium text-center'>
          Un punto de encuentro para personas que aprenden, comparten
          y construyen tecnología desde el Caribe para el mundo.
        </p>
        <div class="flex flex-col justify-center gap-2 items-center md:flex-row md:gap-3">
          {
            BUY_TICKET_URL && (
             <>
              <a
                href={BUY_TICKET_URL}
                target="_blank"
                class='btn btn--primary bg-[#130A26] w-auto'
                data-ga-event="buy_ticket_click"
              >
                Comprar tu ticket
              </a>
              <span class="font-medium text-base">Cupos limitados</span>
             </>
            )
          }
        </div>
      </div>
    </Layout>
    <Layout class="absolute w-full max-w-[1920px] mx-auto bottom-[230px] sm:bottom-[220px] lg:bottom-[190px] xl:bottom-[180px] 2xl:bottom-[160px] z-20 left-1/2 -translate-x-1/2 pointer-events-none">
      <Image
        class='w-full h-full object-cover scale-350 sm:scale-250 lg:scale-180 xl:scale-120 -translate-x-[100px] xl:-translate-x-0'
        src={MuellePuenteSvg}
        alt='Imagen de una bahia de una playa'
      />

      <div class='birds absolute right-0 top-0 translate-x-[0%] translate-y-[-100px] md:translate-y-[-120px] lg:translate-x-[-50%] sm:w-[320px] md:w-[400px] z-10'>
        <Image class='w-full' src={BirdsSvg} alt='Birds image' />
      </div>
    </Layout>
    <div class="w-full absolute bottom-0 pointer-events-none">
      <div class="relative w-full max-w-[1920px] mx-auto z-20">
        <Image
          class='absolute w-[clamp(40px,8vw,100px)] object-cover z-20 right-1/8 md:right-1/3 top-[30px] md:top-[20px]'
          src={BalsaOnePng}
          alt='Imagen de una balsa en el mar'
        />
        <Image
          class='absolute w-[clamp(100px,20vw,250px)] object-cover z-20 right-1/6 top-[40px] md:top-[30px]'
          src={BalsaOnePng}
          alt='Imagen de una balsa en el mar'
        />
        <Image
          class='absolute w-[clamp(100px,20vw,250px)] object-cover z-20 left-1/4 top-[30px]'
          src={BalsaTwoPng}
          alt='Imagen de una balsa en el mar'
        />
      </div>
      <Image
        class='absolute w-[450px] object-cover top-[10px] -translate-y-[50%] left-1/2 z-0 xl:translate-x-[80px] '
        src={SolPng}
        alt='Imagen del sol en el cielo'
        loading='eager'
        fetchpriority='high'
      />
      <Image
        class='relative w-full h-[130px] top-4 object-cover z-10'
        src={AguaPng}
        alt='Imagen de una playa'
        loading='eager'
        fetchpriority='high'
      />
      <Image
        class='relative w-full h-[121px] object-cover z-20 translate-y-[1px]'
        src={PlayaPng}
        alt='Imagen de la arena de una playa'
        loading='eager'
        fetchpriority='high'
      />
    </div>
    <div class="pointer-events-none hidden right-0 left-0 w-full max-w-[1920px] mx-auto absolute bottom-0 z-60 flex translate-y-[100px] lg:flex">
      <Image
        class='w-[450px] h-full object-contain max-h-[clamp(350px,46vw,700px)] -translate-x-[100px]'
        src={PalmasPng}
        alt='Imagen de unas palmas'
      />
    </div>
    <div class="pointer-events-none hidden right-0 left-0 w-full max-w-[1920px] mx-auto absolute bottom-0 z-60 flex justify-end translate-y-[100px] lg:flex">
      <Image
        class='w-[450px] h-full object-contain max-h-[clamp(250px,46vw,700px)] translate-x-[100px]'
        src={PalmaPng}
        alt='Imagen de unas palmas'
      />
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .hero-sponsor-badge {
    background: #FFFFFF1F;
    border: 1px solid #FFFFFF3D;
    box-shadow: inset 0 1px 1px 0 #FFFFFF33, 0 4px 16px -4px #00000033;
    backdrop-filter: blur(6px);
  }

  .hero-sponsor-badge:hover {
    background: #FFFFFF2E;
    border-color: #FFFFFF59;
  }
</style>
