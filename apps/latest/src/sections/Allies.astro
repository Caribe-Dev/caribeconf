---
import { Image } from 'astro:assets';
import { allies } from '@/utils/constants';

import Layout from '@shared/components/Layout.astro';

---
<Layout id='aliados' class='w-full flex flex-col items-center gap-20 pt-20 pb-50 lg:gap-30'>
  <h2 class="h2 text-white font-bold text-center z-20">Aliados</h2>
  <div class="flex flex-wrap justify-center items-center gap-20 max-w-[1000px] w-full">
    {
      allies.map((ally) => {
        const alt = `Logo de ${ally.name}`;
        return (
          <a class="ally" href={ally.url} target='_blank' rel='noopener noreferrer'>
            <Image
              title={alt}
              src={ally.img}
              alt={alt}
              width={240}
              height={96}
              style={`--h:${ally.h ?? 40}px`}
            />
          </a>
        )
      })
    }
  </div>
</Layout>

<style>
  @reference "../styles/global.css";

  .ally {
    @apply flex items-center justify-center transition-transform hover:scale-[1.05];
    min-height: 60px;
  }

  .ally :global(img) {
    /* Mobile: escala todos los logos por igual (preserva la normalización por área) */
    height: calc(var(--h) * 0.85);
    width: auto;
    max-width: 180px;
    object-fit: contain;
  }

  @media (min-width: 1024px) {
    .ally {
      min-height: 96px;
    }

    .ally :global(img) {
      height: var(--h);
      max-width: 200px;
    }
  }
</style>