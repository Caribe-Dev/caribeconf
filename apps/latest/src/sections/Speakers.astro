---

import { Image } from 'astro:assets';

import Layout from "@shared/components/Layout.astro";
import SpeakerCard from '@shared/components/SpeakerCard.astro';
import VerticalDivider from '@/components/VerticalDivider.astro';

import VectorBottom from '@/public/images/vector-bottom.svg';
import PalmasPng from '@/public/images/palmeras-izquierda.png';
import VectorTop from '@/public/images/purple-vector-top.svg';
import BirdsSvg from '@/public/images/birds.svg';

import InstagramSvg from '@shared/components/Svgs/Instagram.astro';
import WebsiteSvg from '@shared/components/Svgs/LaptopIcon.astro';
import LinkedInSvg from '@shared/components/Svgs/LinkedIn.astro';
import ChevronLeftSvg from '@shared/components/Svgs/ChevronLeft.astro';
import ChevronRightSvg from '@shared/components/Svgs/ChevronRight.astro';

import { speakers, speakerToBeConfirmed } from '@/utils/constants';
import { FLAGS } from '@shared/utils/constants';


const remainingSpeakers = 14 - speakers.length

const allSpeakers = [
  ...speakers,
  ...Array.from({ length: remainingSpeakers }).map(() => speakerToBeConfirmed),
]

const uniqueImages = [...new Set(allSpeakers.map(s => s?.image || speakerToBeConfirmed.image).filter(Boolean))]
const uniqueFlags = [...new Set(allSpeakers.map(s => s?.country ? FLAGS[s.country] : '').filter(Boolean))]
---

{uniqueImages.map((url, i) => (
  <link rel={i === 0 ? 'preload' : 'prefetch'} as="image" href={url} />
))}
{uniqueFlags.map(url => (
  <link rel="prefetch" as="image" href={url} />
))}

<section id="speakers" class="relative overflow-hidden">
  <div class="relative flex justify-center gradient-bg-1">
    <div class="absolute top-[-2px] pointer-events-none" aria-hidden="true">
      <Image
        class='w-full h-full'
        src={VectorTop}
        alt=''
      />
    </div>
    <Layout class="relative w-full flex flex-col pt-[120px] lg:pt-[160px]">
      <h2 class="h2 text-white font-bold text-center z-20">Speakers</h2>
      <div class='pointer-events-none absolute right-0 translate-y-[70px] translate-x-[60px] md:translate-x-[0px] md:translate-y-[70px] xl:translate-y-[0px] sm:w-[350px] md:w-[450px] z-10'>
        <Image class='w-full' src={BirdsSvg} alt='Birds image' />
      </div>
      <div class="mt-20 md:mt-40 lg:mt-60 relative">
        <div class="absolute bottom-0 left-0 pointer-events-none translate-x-[-30px] z-10">
          <Image
            class='w-auto h-[220px] sm:h-[300px] md:h-[350px] lg:w-[450px] lg:h-auto object-contain max-h-[clamp(350px,46vw,600px)] '
            src={PalmasPng}
            alt='Imagen de unas palmas'
          />
        </div>
        <div class="flex justify-center speaker-background before:max-w-[320px] md:before:max-w-[400px] lg:before:max-w-[500px]">
          <div class="relative w-full max-w-[320px] md:max-w-[400px] lg:max-w-[500px] flex items-center justify-center">
            <button type="button" class="js-prev-speaker speaker-nav-btn speaker-nav-btn--prev" aria-label="Speaker anterior">
              <ChevronLeftSvg />
            </button>
            <div class='flex justify-center w-full max-w-[400px] lg:max-w-[450px] relative js-speaker-card z-20'>
              <img
                class='w-full h-[280px] md:h-[400px] lg:h-[480px] object-contain mask-speaker js-speaker-image'
                src='https://res.cloudinary.com/dpu0uajtw/image/upload/v1741668329/speaker_gndva4.webp'
                alt='Imagen de conferencista'
              />
              <div class='flex flex-col items-center md:gap-[5px] absolute bottom-0'>
                <img
                  class='hidden relative left-[10px] w-full max-w-[65px] md:max-w-[140px] js-country-flag'
                  src='https://res.cloudinary.com/dpu0uajtw/image/upload/v1741747850/colombia-flag_o0xnlj.webp'
                  alt='Bandera de Colombia'
                />
                <p class='h5 js-speaker-name'></p>
                <span class='js-speaker-role'></span>
                <div class='js-speaker-social h-[32px] flex justify-between items-center'></div>
              </div>
              <div class="hidden">
                <span id="tpl-instagram">
                  <InstagramSvg height="29" width="29" />
                </span>
                <span id="tpl-website">
                  <WebsiteSvg />
                </span>
                <span id="tpl-linkedin">
                  <LinkedInSvg  height="29" width="29" />
                </span>
              </div>
            </div>
            <button type="button" class="js-next-speaker speaker-nav-btn speaker-nav-btn--next" aria-label="Siguiente speaker">
              <ChevronRightSvg />
            </button>
          </div>
        </div>
        <div class="absolute bottom-0 right-0 pointer-events-none translate-x-[30px]">
          <Image
            class='w-auto h-[220px] sm:h-[300px] md:h-[350px] lg:w-[450px] lg:h-auto object-contain max-h-[clamp(350px,46vw,600px)] -scale-x-100'
            src={PalmasPng}
            alt='Imagen de unas palmas'
          />
        </div>
      </div>
    </Layout>
    <div class="absolute bottom-[23px] pointer-events-none z-10" aria-hidden="true">
      <Image
        class='w-full h-full'
        src={VectorBottom}
        alt=''
      />
    </div>
  </div>
  <div class="gradient-bg-2 relative mt-[-24px] z-10">
    <Layout class="relative w-full flex flex-col pt-[30px] lg:pt-[80px] pb-[100px] lg:pb-[200px] gap-[120px]">
      <div class="flex snap-x snap-mandatory overflow-x-scroll w-full js-carrousel carousel-mobile speaker-pyramid gap-4 md:gap-10">
        {allSpeakers.map((speaker, i) => {
          const isFirst = i === 0
          const isLast = i === allSpeakers.length - 1
          return (
            <div class:list={['w-30 shrink-0 snap-center', { 'ml-[calc(50%-60px)]': isFirst, 'mr-[calc(50%-60px)]': isLast }]}>
              <SpeakerCard
                class:list={['js-speaker-card max-w-50', { 'active': i === 0 }]}
                thumbnail={speaker?.thumbnail || speakerToBeConfirmed.image}
                name={speaker?.name || speakerToBeConfirmed.name}
                role={speaker?.role || speakerToBeConfirmed.role}
                country={speaker?.country}
                image={speaker?.image || speakerToBeConfirmed.image}
                socialType={speaker?.social?.type}
                socialUrl={speaker?.social?.url}
                alt={`Foto del speaker ${speaker?.name || 'por confirmar'}`}
              />
            </div>
          )
        })}
      </div>
      <div class="become-speaker flex flex-col w-full lg:items-center gap-[20px] p-[30px] lg:p-[50px] lg:gap-[50px] lg:flex-row rounded-[19px]">
        <h2 class="h3 text-[#FBC273] font-bold text-left lg:py-5 lg:max-w-[400px]">
          ¡Nuestros speakers!
        </h2>
        <div class="hidden lg:block self-stretch">
          <VerticalDivider />
        </div>
        <div class="flex flex-col gap-8 w-full lg:py-5">
          <div class="flex flex-col gap-4 w-full">
            <p class="small-text text-white text-left">
              Un grupo diverso de expertos y expertas comparte su conocimiento,
              experiencias y aprendizajes con la comunidad tecnológica del Caribe.
            </p>
            <p class="small-text text-white text-left">
              Charlas y workshops prácticos, reales y cercanos.
            </p>
          </div>
        </div>
      </div>
    </Layout>
  </div>
</section>

<style>
  .gradient-bg-1 {
    background: linear-gradient(180deg,#494DBE 11.81%,#845BBC 26.77%,#925DB3 34.23%,#C96980 89.68%);
  }

  .gradient-bg-2 {
    background: linear-gradient(180deg,#130A26 5.31%,#F26457 223.14%);
  }

  .become-speaker {
    box-shadow: 0px 0px 20.1px 0px #D9667BA3;
    background: #FFFFFF12;
  }

  .speaker-background {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .speaker-background:before {
    content: '';
    position: absolute;
    width: 100%;
    bottom: 5px;
    aspect-ratio: 1/1;
    border-radius: 999px;
    background: linear-gradient(180deg, #F2884B 58.17%, #9963B7 100%);
  }

  .mask-speaker {
    mask-image: linear-gradient(#000 60%, #0000 100%);
  }

  .speaker-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    color: #fff;
    background: #FFFFFF33;
    border: 1px solid #FFFFFF59;
    box-shadow: 0 2px 10px 0 #00000026;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .speaker-nav-btn:hover {
    background: #FFFFFF52;
    transform: translateY(-50%) scale(1.08);
  }

  .speaker-nav-btn:active {
    transform: translateY(-50%) scale(0.96);
  }

  .speaker-nav-btn--prev {
    left: -4px;
  }

  .speaker-nav-btn--next {
    right: -4px;
  }

  @media (min-width: 768px) {
    .speaker-nav-btn {
      width: 44px;
      height: 44px;
    }

    .speaker-nav-btn--prev {
      left: -10px;
    }

    .speaker-nav-btn--next {
      right: -10px;
    }
  }

  .carousel-mobile {
    -ms-overflow-style: none;
    scrollbar-width: none;
    overflow-y: clip;
    padding-block: 50px;
  }

  .carousel-mobile::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 1024px) {
    .speaker-pyramid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      overflow: visible;
      column-gap: 3.75rem;
      row-gap: 2.5rem;
      padding-block: 3.125rem;
    }

    .speaker-pyramid > * {
      width: calc((100% - 5 * 3.75rem) / 6);
      flex-shrink: 0;
      margin-left: 0 !important;
      margin-right: 0 !important;
      scroll-snap-align: none;
    }
  }
</style>

<script>
  import { FLAGS } from '@shared/utils/constants'

  const UNCONFIRMED = 'Por Confirmar'

  document.addEventListener('astro:page-load', () => {
    const $speakerCard: HTMLImageElement | null = document.querySelector('.js-speaker-card')
    const $speakerImage: HTMLImageElement | null = document.querySelector('.js-speaker-image')
    const $speakerName: HTMLImageElement | null = document.querySelector('.js-speaker-name')
    const $speakerRole: HTMLImageElement | null = document.querySelector('.js-speaker-role')
    const $speakerSocial: HTMLDivElement | null = document.querySelector('.js-speaker-social')
    const $countryImage: HTMLImageElement | null = document.querySelector('.js-country-flag')
    const $speakers: NodeListOf<HTMLDivElement> = document.querySelectorAll('.js-speaker-card')
    const $carrousel = document.querySelector('.js-carrousel')
    const mobileMediaQuery = window.matchMedia('(max-width: 1024px)')

    const $realSpeakers = Array.from($speakers).filter(
      ($el) => $el !== $speakerCard && $el.dataset.speakerName !== UNCONFIRMED
    )
    let activeRealIndex = Math.max(0, $realSpeakers.findIndex(($el) => $el.classList.contains('active')))

    const setActiveSpeaker = ($speakerElem: HTMLDivElement) => {
      const realIndex = $realSpeakers.indexOf($speakerElem)
      if (realIndex !== -1) activeRealIndex = realIndex

      const {
        speakerImage = '',
        speakerName,
        speakerRole,
        speakerCountry,
        socialType,
        socialUrl
      } = $speakerElem.dataset

      if ($speakerImage && speakerImage) {
        $speakerImage.src = speakerImage
        $speakerImage.alt = `${speakerName} image`
        $speakerCard?.classList.add('z-10')
      }

      if ($speakerName && speakerName) {
        $speakerName.textContent = speakerName
      }

      if ($speakerRole && speakerRole) {
        $speakerRole.textContent = speakerRole
      }

      if ($countryImage && speakerCountry && FLAGS[speakerCountry]) {
        $countryImage.src = FLAGS[speakerCountry]
        $countryImage.alt = 'Bandera de ' + speakerCountry
        $countryImage.classList.remove('hidden')
      }

      if ($speakerSocial) {
        if (socialType && socialUrl) {
          const tplId = `tpl-${socialType}`
          const svgHtml = document.getElementById(tplId)?.innerHTML ?? ''
          $speakerSocial.innerHTML = `<a href="${socialUrl}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2">${svgHtml}</a>`
        } else {
          $speakerSocial.innerHTML = ''
        }
      }
    }

    let isProgrammaticScroll = false
    let scrollEndTimer: ReturnType<typeof setTimeout>

    const onSetActiveSpeaker = ($speakerElem: HTMLDivElement) => {
      if (mobileMediaQuery.matches) {
        isProgrammaticScroll = true
        clearTimeout(scrollEndTimer)
        $speakerElem.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' })
        return
      }

      const isUnConfirmed = $speakerElem?.dataset?.speakerName === UNCONFIRMED

      if (isUnConfirmed) return

      const $activeSpeaker: HTMLDivElement | null  = document.querySelector('.js-speaker-card.active')

      if ($activeSpeaker === $speakerElem) return

      $activeSpeaker?.classList.remove('active')
      setActiveSpeaker($speakerElem)
      $speakerElem.classList.add('active')
    }

    $speakers.forEach(($speaker) => {
      if ($speaker === $speakerCard) return
      $speaker.addEventListener('click', () => onSetActiveSpeaker($speaker))
    })

    const $prevSpeakerBtn: HTMLButtonElement | null = document.querySelector('.js-prev-speaker')
    const $nextSpeakerBtn: HTMLButtonElement | null = document.querySelector('.js-next-speaker')

    const navigateSpeaker = (direction: 1 | -1) => {
      if (!$realSpeakers.length) return
      activeRealIndex = (activeRealIndex + direction + $realSpeakers.length) % $realSpeakers.length
      onSetActiveSpeaker($realSpeakers[activeRealIndex])
    }

    $prevSpeakerBtn?.addEventListener('click', () => navigateSpeaker(-1))
    $nextSpeakerBtn?.addEventListener('click', () => navigateSpeaker(1))

    if (mobileMediaQuery.matches && $carrousel) {
      const $activeSpeaker: HTMLDivElement | null = $carrousel.querySelector('.js-speaker-card.active')
      const $allSpeakerCard = $carrousel.querySelectorAll('.js-speaker-card')

      if ($activeSpeaker) {
        setActiveSpeaker($activeSpeaker)
      }

      const activateCenteredCard = () => {
        isProgrammaticScroll = false
        $allSpeakerCard.forEach(($elm) => {
          const rect = $elm.getBoundingClientRect()
          const { width } = $carrousel.getBoundingClientRect()
          if (
            rect.left > width / 2 - rect.width * 0.75 &&
            rect.left < width / 2 + rect.width * 0.25
          ) {
            const isUnConfirmed = ($elm as HTMLDivElement).dataset?.speakerName === UNCONFIRMED
            if (!isUnConfirmed) {
              const $active: HTMLDivElement | null = $carrousel.querySelector('.js-speaker-card.active')
              $active?.classList.remove('active')
              setActiveSpeaker($elm as HTMLDivElement)
              $elm.classList.add('active')
            }
          }
        })
      }

			$carrousel.addEventListener('scroll', () => {
        clearTimeout(scrollEndTimer)
        scrollEndTimer = setTimeout(activateCenteredCard, 150)

        if (isProgrammaticScroll) return

        $allSpeakerCard.forEach(($elm) => {
          const rect = $elm.getBoundingClientRect()
          const { width } = $carrousel.getBoundingClientRect()

          if (
            rect.left > width / 2 - rect.width * 0.75 &&
            rect.left < width / 2 + rect.width * 0.25
          ) {
            const $activeSpeaker: HTMLDivElement | null = $carrousel.querySelector('.js-speaker-card.active')
            $activeSpeaker?.classList.remove('active')

            const isUnConfirmed = ($elm as HTMLDivElement).dataset?.speakerName === UNCONFIRMED

            if (!isUnConfirmed) {
              setActiveSpeaker($elm as HTMLDivElement)
              $elm.classList.add('active')
            }
          }
        })
			}, { passive: true })

      return
		}

    const $activeSpeaker: HTMLDivElement | null = document.querySelector('.js-speaker-card.active')

    if ($activeSpeaker){
      setActiveSpeaker($activeSpeaker)
    }
  })

</script>