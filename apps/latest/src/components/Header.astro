---
import { Image } from 'astro:assets';

import { BUY_TICKET_URL } from "@/utils/constants";

import Layout from '@shared/components/Layout.astro';
import InstagramSvg from '@shared/components/Svgs/Instagram.astro';
import TwitchSvg from '@shared/components/Svgs/Twitch.astro';
import GithubSvg from '@shared/components/Svgs/Github.astro';
import TwitterSvg from '@shared/components/Svgs/Twitter.astro';
import LinkedInSvg from '@shared/components/Svgs/LinkedIn.astro';
import CaribeDevPng from '@/public/caribe-dev-white-logo.png';
---

<Layout id='header' class='px-0! lg:px-4! group'>
  <nav class='group-[.open]:fixed group-[.open]:inset-0 group-[.open]:h-dvh group-[.open]:bg-purple flex flex-col lg:flex-row lg:justify-between lg:items-center px-4 lg:px-6 py-5 lg:py-4 gap-[30px] lg:gap-4 backdrop-blur lg:bg-white/10 lg:rounded-3xl'>
    <div class='flex justify-between items-center gap-3'>
      <a href='/' class='flex justify-between items-center gap-3'>
        <Image class='max-w-[65px] lg:max-w-[50px]' src={CaribeDevPng} alt='Caribe dev logo' />
        <span class='font-semibold'>14 y 15 de Agosto 2026</span>
      </a>
      <button
        id='menu-btn'
        aria-expanded='false'
        aria-controls='menu-content'
        class='flex h-5 flex-col items-center justify-between lg:hidden w-6 cursor-pointer'
        aria-label='Abrir menú de navegación'
      >
        <span class='bg-gray-300 group-[.open]:translate-y-2 group-[.open]:rotate-45 h-[2px] w-6 transition ease transform duration-300'></span>
        <span class='bg-gray-300 group-[.open]:opacity-0 h-[2px] w-6 transition ease transform duration-300'></span>
        <span class='bg-gray-300 group-[.open]:-translate-y-[0.6rem] group-[.open]:-rotate-45 h-[2px] w-6 transition ease transform duration-300'></span>
      </button>
    </div>
    <ul id='menu-content' class='hidden group-[.open]:flex lg:flex flex-col lg:flex-row justify-between items-center gap-[24px]'>
      <li><a href='#about-us' class='font-semibold'>Sponsors</a></li>
      <li><a href='#speakers' class='font-semibold'>Speakers</a></li>
      <li><a href='#agenda' class='font-semibold'>Agenda</a></li>
      <li><a href='#aliados' class='font-semibold'>Aliados</a></li>
      {
        BUY_TICKET_URL && (
          <li>
            <a
              href={BUY_TICKET_URL}
              target="_blank"
              class='btn btn--primary btn--pink lg:bg-[#130A26] w-fit'
              data-ga-event="buy_ticket_click"
            >
              Comprar tu ticket
            </a>
          </li>
        )
      }
    </ul>
    <div class='hidden group-[.open]:flex flex-1 justify-end gap-[16px] flex-col md:hidden'>
      <div class='flex gap-[16px] justify-center items-end'>
        <a href="https://www.instagram.com/caribedev/" target="_blank" rel="noopener">
          <span class="sr-only">Instagram</span>
          <InstagramSvg width={25} height={26} />
        </a>
        <a href="https://www.twitch.tv/caribedev" target="_blank" rel="noopener">
          <span class="sr-only">Twitch</span>
          <TwitchSvg width={25} height={26} />
        </a>
        <a href="https://x.com/caribedev" target="_blank" rel="noopener">
          <span class="sr-only">LinkedIn</span>
          <TwitterSvg width={25} height={26} />
        </a>
        <a href="https://www.linkedin.com/company/caribe-dev/" target="_blank" rel="noopener">
          <span class="sr-only">LinkedIn</span>
          <LinkedInSvg width={25} height={26} />
        </a>
        <a href="https://github.com/caribe-dev" target="_blank" rel="noopener">
          <span class="sr-only">Twitch</span>
          <GithubSvg width={25} height={26} />
        </a>
      </div>
      <div class="text-center">
        <a
          class="text-white font-semibold underline"
          href="https://github.com/Caribe-Dev/caribe-page/blob/main/CODE_OF_CONDUCT.md"
          target="_blank"
          rel="noopener"
        >
          Code of Conduct
        </a>
      </div>
    </div>
  </nav>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const $header = document.getElementById('header')
    const $menuBtn = document.getElementById('menu-btn')
    const $menuContent = document.getElementById('menu-content')
    const menuButtonAriaLabel = {
      open: 'Cerrar menú de navegación',
      close: 'Abrir menú de navegación'
    }

    const handleSmoothScroll = (selector: string) => {
      const element = document.querySelector(selector)

      if (!element) return

      element.scrollIntoView({
        behavior: 'smooth',
      })
    }

    $menuBtn?.addEventListener('click', function () {
      const expanded = this.getAttribute('aria-expanded') === 'true'
      const arialLabel = !expanded ? menuButtonAriaLabel.close: menuButtonAriaLabel.open

      this.setAttribute('aria-expanded', `${!expanded}`)
      this.setAttribute('aria-label', arialLabel)
      $header?.classList.toggle('open')
    })

    $menuContent?.addEventListener('click', function (e) {
      const $anchor = (e.target as Element).closest('a')

      if ($anchor) {
        const id = $anchor.getAttribute('href') || ''
        
        if (id.startsWith('#')) {
          e.preventDefault()

          $header?.classList.remove('open')
          handleSmoothScroll(id)
        }
      }
    })
	})
</script>
