---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'svg'>

const { stroke = 'currentColor', width = 12, height = 20, ...props } = Astro.props
---

<svg viewBox="0 0 12 20" fill="none" height={height} width={width} {...props}>
  <path d="M2 2L10 10L2 18" stroke={stroke} stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
