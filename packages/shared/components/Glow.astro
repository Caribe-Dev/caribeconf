---
---
<div class="glow"></div>
<div class="aura">
  <div class="aura-spin"></div>
</div>

<style>
  .glow {
    position: fixed;
    bottom: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse at center, #9333ea 0%, #7c3aed55 40%, transparent 70%);
    filter: blur(60px);
    border-radius: 50%;
    pointer-events: none;
  }

  .aura {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 100;
    -webkit-mask-image:
      linear-gradient(to bottom, white 0px, transparent 8px),
      linear-gradient(to top,    white 0px, transparent 8px),
      linear-gradient(to right,  white 0px, transparent 8px),
      linear-gradient(to left,   white 0px, transparent 8px);
    -webkit-mask-composite: source-over, source-over, source-over;
    mask-image:
      linear-gradient(to bottom, white 0px, transparent 8px),
      linear-gradient(to top,    white 0px, transparent 8px),
      linear-gradient(to right,  white 0px, transparent 8px),
      linear-gradient(to left,   white 0px, transparent 8px);
    mask-composite: add, add, add;
  }

  .aura-spin {
    position: absolute;
    inset: -100%;
    background: conic-gradient(
      from 0deg,
      transparent       0deg,
      #41DEF4          50deg,
      #1EB8F9          90deg,
      #9333ea         150deg,
      #BE357F         200deg,
      transparent     230deg,
      transparent     320deg,
      #41DEF4         360deg
    );
    filter: blur(18px);
    opacity: 0.45;
    animation: aura-spin-rotate 7s linear infinite;
  }

  @keyframes aura-spin-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
</style>
