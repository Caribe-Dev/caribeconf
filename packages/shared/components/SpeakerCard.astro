---
import { cnx } from '../utils/csx';

interface Props {
	class?: string
	thumbnail: string
	image: string
  name: string
  role?: string
  country?: string
  socialType?: string
  socialUrl?: string
	alt: string
}

const {
  class: className,
  name, role,
  country,
  thumbnail,
  image,
  alt,
  socialType,
  socialUrl
} = Astro.props

const thumbSrc = thumbnail.includes('/upload/')
  // If the thumbnail is from Cloudinary, we can optimize it by requesting a
  // smaller size and using automatic format and quality.
  ? thumbnail.replace('/upload/', '/upload/w_240,f_auto,q_auto/')
  : thumbnail
---
<div
  class={cnx('speaker-card max-w-[120px]', className)}
  data-speaker-name={name}
  data-speaker-role={role}
  data-speaker-country={country}
  data-speaker-image={image}
  data-social-type={socialType}
  data-social-url={socialUrl}
  title={name}
>
  <img
    class='speaker-card__img'
    src={thumbSrc}
    alt={alt}
    loading='eager'
    decoding='async'
  />
</div>

<style>
  @reference "tailwindcss";

  .speaker-card {
    @apply cursor-pointer w-full grayscale aspect-[1] object-cover opacity-80 transition-[transform,opacity];
    position: relative;
    isolation: isolate;
  }

  .speaker-card__img {
    @apply w-full object-contain h-full;
    mask-image: radial-gradient(ellipse 75% 80% at 50% 42%, #000 40%, #0000 72%);
  }

  .speaker-card.active {
    @apply opacity-100 scale-[1.05] grayscale-0;
  }

  .speaker-card.active::before {
    content: '';
    position: absolute;
    inset: -18px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(190, 53, 127, 0.85) 0%, rgba(153, 99, 183, 0.5) 40%, transparent 70%);
    -webkit-filter: blur(20px);
    filter: blur(20px);
    z-index: -1;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }
</style>