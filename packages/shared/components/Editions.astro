---
const editions = [
  { label: '2025', url: 'https://2025.caribeconf.com' },
  { label: '2026', url: 'https://www.caribeconf.com' },
]
---

<div class="relative inline-block border border-white rounded-xl w-fit px-[12px] py-[6px]">
  <button
    id="editions-btn"
    aria-expanded="false"
    aria-haspopup="listbox"
    class="flex items-center gap-1.5 font-semibold cursor-pointer hover:opacity-80 transition-opacity"
  >
    Ediciones
    <svg
      id="editions-chevron"
      class="w-3.5 h-3.5 transition-transform duration-200"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <ul
    id="editions-menu"
    role="listbox"
    class="hidden absolute bottom-[calc(100%+10px)] left-0 w-full bg-purple border border-white/10 rounded-2xl overflow-hidden shadow-2xl shadow-black/40"
  >
    {editions.map(({ label, url }) => (
      <li>
        <a
          href={url}
          target="_blank"
          rel="noopener"
          class="block px-5 py-3 font-semibold hover:bg-white/10 transition-colors whitespace-nowrap"
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('editions-btn')
    const menu = document.getElementById('editions-menu')
    const chevron = document.getElementById('editions-chevron')

    function openMenu() {
      btn?.setAttribute('aria-expanded', 'true')
      menu?.classList.remove('hidden')
      chevron?.classList.add('rotate-180')
    }

    function closeMenu() {
      btn?.setAttribute('aria-expanded', 'false')
      menu?.classList.add('hidden')
      chevron?.classList.remove('rotate-180')
    }

    btn?.addEventListener('click', (e) => {
      e.stopPropagation()
      btn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu()
    })

    document.addEventListener('click', closeMenu)

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu()
    })
  })
</script>
